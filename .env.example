# Next.js 前端请求的 API 根路径。
NEXT_PUBLIC_API_BASE_URL=/api

# Next.js 服务端直连 MySQL 所需的数据库配置。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=xfy_bs

# 登录态与基础评测逻辑使用的服务端密钥和超时配置。
JWT_SECRET=your-secret-key-change-in-production
CODE_EXECUTION_TIMEOUT=5000

# Redis 用于排行榜缓存与异步评测队列；未启用或不可用时会自动降级为直查数据库 + 同步评测。
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=oj-next

# 异步评测消费者并发数，建议开发环境从 1 开始。
JUDGE_WORKER_CONCURRENCY=1
